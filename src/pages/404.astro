---
import Layout from "@/layouts/Layout.astro";
import Glass from "@/components/Glass.astro";
import PatternBG from "@/components/PatternBG.astro";
import Logo from "@/components/Logo.astro";
import Link from "@/components/Link.astro";
import { LINKS } from "@/lib/constants";
import { getI18N } from "@/i18n/index";

const { currentLocale } = Astro;
const i18n = getI18N({ currentLocale });
const homePath = currentLocale === "en" ? "/en/" : "/";
---

<Layout title="Eco_Page_404" description="404">
    <PatternBG>
        <main class="not-found-shell px-4 py-12 sm:px-6 lg:px-10">
            <section class="mx-auto grid min-h-full w-full max-w-6xl place-items-center">
                <Glass class="error-console w-full overflow-hidden p-0" glow={true} pixelEffect={true}>
                    <div class="console-grid">
                        <div class="console-main">
                            <div class="terminal-bar" aria-hidden="true">
                                <span></span>
                                <span></span>
                                <span></span>
                            </div>

                            <p class="eyebrow">{i18n.Not_Found.eyebrow}</p>
                            <h1 class="error-code" aria-label="404">404</h1>
                            <h2>{i18n.Not_Found.title}</h2>
                            <p class="description">{i18n.Not_Found.description}</p>

                            <div class="actions" aria-label="404 actions">
                                <Link href={homePath} class="primary-action">
                                    {i18n.Not_Found.home}
                                </Link>
                                <Link href={LINKS.github} blank={true} class="secondary-action">
                                    {i18n.Not_Found.github}
                                </Link>
                            </div>
                        </div>

                        <aside class="diagnostics" aria-label="Route diagnostics">
                            <div class="logo-orbit" aria-hidden="true">
                                <Logo class="w-24 sm:w-32" />
                            </div>
                            <div class="terminal-lines">
                                <p><span>$</span> {i18n.Not_Found.terminal_status}</p>
                                <p><span>$</span> {i18n.Not_Found.terminal_origin}</p>
                                <p><span>$</span> {i18n.Not_Found.terminal_action}<b class="cursor">_</b></p>
                            </div>
                            <p class="hint">{i18n.Not_Found.hint}</p>
                        </aside>
                    </div>
                </Glass>
            </section>
        </main>
    </PatternBG>
</Layout>

<script is:inline>
    const consolePanel = document.querySelector(".error-console");

    if (consolePanel && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        consolePanel.addEventListener("pointermove", (event) => {
            const rect = consolePanel.getBoundingClientRect();
            const x = ((event.clientX - rect.left) / rect.width - 0.5) * 2;
            const y = ((event.clientY - rect.top) / rect.height - 0.5) * 2;

            consolePanel.style.setProperty("--tilt-x", `${y * -4}deg`);
            consolePanel.style.setProperty("--tilt-y", `${x * 5}deg`);
            consolePanel.style.setProperty("--spot-x", `${event.clientX - rect.left}px`);
            consolePanel.style.setProperty("--spot-y", `${event.clientY - rect.top}px`);
        });

        consolePanel.addEventListener("pointerleave", () => {
            consolePanel.style.setProperty("--tilt-x", "0deg");
            consolePanel.style.setProperty("--tilt-y", "0deg");
            consolePanel.style.setProperty("--spot-x", "50%");
            consolePanel.style.setProperty("--spot-y", "50%");
        });
    }
</script>

<style>
    .not-found-shell {
        position: relative;
        isolation: isolate;
        display: grid;
        min-height: 100vh;
        min-height: 100svh;
        place-items: center;
    }

    .not-found-shell::before,
    .not-found-shell::after {
        content: "";
        position: absolute;
        inset: 10% auto auto 8%;
        width: 22rem;
        height: 22rem;
        border-radius: 999px;
        background: rgba(148, 111, 179, 0.16);
        filter: blur(70px);
        pointer-events: none;
        z-index: -1;
    }

    .not-found-shell::after {
        inset: auto 8% 12% auto;
        width: 18rem;
        height: 18rem;
        background: rgba(84, 33, 135, 0.2);
    }

    .error-console {
        --tilt-x: 0deg;
        --tilt-y: 0deg;
        --spot-x: 50%;
        --spot-y: 50%;
        transform: perspective(1200px) rotateX(var(--tilt-x)) rotateY(var(--tilt-y));
        transition: transform 220ms ease, border-color 220ms ease;
    }

    .error-console::after {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at var(--spot-x) var(--spot-y), rgba(222, 210, 232, 0.12), transparent 30%);
        opacity: 0.9;
        pointer-events: none;
    }

    .console-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.3fr) minmax(280px, 0.7fr);
        min-height: 520px;
    }

    .console-main,
    .diagnostics {
        position: relative;
        z-index: 1;
        padding: clamp(1.5rem, 4vw, 3.5rem);
    }

    .console-main {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .terminal-bar {
        position: absolute;
        top: 1.25rem;
        left: clamp(1.5rem, 4vw, 3.5rem);
        display: flex;
        gap: 0.5rem;
    }

    .terminal-bar span {
        width: 0.7rem;
        height: 0.7rem;
        border-radius: 999px;
        background: #946fb3;
        box-shadow: 0 0 18px rgba(148, 111, 179, 0.65);
    }

    .terminal-bar span:nth-child(2) {
        opacity: 0.7;
    }

    .terminal-bar span:nth-child(3) {
        opacity: 0.45;
    }

    .eyebrow {
        margin-top: 2rem;
        font-family: "satoshi", sans-serif;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        color: #ad8fc5;
    }

    .error-code {
        margin-top: 0.5rem;
        font-family: "Cabinet Grotesk", sans-serif;
        font-size: clamp(6rem, 18vw, 15rem);
        font-weight: 900;
        line-height: 0.78;
        letter-spacing: -0.08em;
        color: transparent;
        -webkit-text-stroke: 1px rgba(222, 210, 232, 0.72);
        text-shadow: 0 0 45px rgba(148, 111, 179, 0.34);
    }

    h2 {
        margin-top: 1.5rem;
        max-width: 760px;
        font-family: "Cabinet Grotesk", sans-serif;
        font-size: clamp(2rem, 5vw, 4.5rem);
        font-weight: 800;
        line-height: 0.95;
        letter-spacing: -0.04em;
    }

    .description {
        margin-top: 1.25rem;
        max-width: 660px;
        font-family: "satoshi", sans-serif;
        font-size: clamp(1rem, 2vw, 1.15rem);
        line-height: 1.75;
        color: rgba(255, 255, 255, 0.72);
    }

    .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem;
        margin-top: 2rem;
    }

    .primary-action,
    .secondary-action {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 3rem;
        border-radius: 0.85rem;
        padding: 0 1.15rem;
        font-family: "satoshi", sans-serif;
        font-weight: 800;
        transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
    }

    .primary-action {
        background: #ded2e8;
        color: #0f1115;
        box-shadow: 4px 4px 0 rgba(31, 15, 45, 0.95);
    }

    .secondary-action {
        border: 1px solid rgba(173, 143, 197, 0.35);
        background: rgba(15, 17, 21, 0.46);
        color: #ded2e8;
    }

    .primary-action:hover,
    .secondary-action:hover {
        transform: translateY(-2px);
    }

    .diagnostics {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        border-left: 1px solid rgba(148, 111, 179, 0.18);
        background:
            linear-gradient(rgba(222, 210, 232, 0.04) 1px, transparent 1px),
            linear-gradient(90deg, rgba(222, 210, 232, 0.04) 1px, transparent 1px),
            rgba(5, 1, 7, 0.18);
        background-size: 28px 28px;
    }

    .logo-orbit {
        display: grid;
        place-items: center;
        width: min(100%, 16rem);
        aspect-ratio: 1;
        margin-inline: auto;
        border: 1px dashed rgba(173, 143, 197, 0.35);
        border-radius: 999px;
        background: radial-gradient(circle, rgba(148, 111, 179, 0.18), transparent 62%);
        animation: pulse-orbit 4s ease-in-out infinite;
    }

    .terminal-lines {
        display: grid;
        gap: 0.85rem;
        margin-top: 2rem;
        font-family: ui-monospace, SFMono-Regular, Consolas, "Liberation Mono", monospace;
        font-size: 0.92rem;
        color: rgba(222, 210, 232, 0.8);
    }

    .terminal-lines span {
        color: #946fb3;
    }

    .cursor {
        animation: cursor-blink 1s steps(2, jump-none) infinite;
        color: #ded2e8;
    }

    .hint {
        margin-top: 2rem;
        font-family: "satoshi", sans-serif;
        font-size: 0.9rem;
        line-height: 1.6;
        color: rgba(255, 255, 255, 0.58);
    }

    @keyframes cursor-blink {
        50% {
            opacity: 0;
        }
    }

    @keyframes pulse-orbit {
        50% {
            box-shadow: 0 0 60px -24px rgba(222, 210, 232, 0.8);
            transform: scale(1.025);
        }
    }

    @media (max-width: 860px) {
        .console-grid {
            grid-template-columns: 1fr;
        }

        .diagnostics {
            border-top: 1px solid rgba(148, 111, 179, 0.18);
            border-left: 0;
        }

        .logo-orbit {
            width: 11rem;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .error-console,
        .logo-orbit,
        .cursor,
        .primary-action,
        .secondary-action {
            animation: none;
            transition: none;
            transform: none;
        }
    }
</style>
