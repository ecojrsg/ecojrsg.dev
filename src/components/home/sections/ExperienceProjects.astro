---
import "swiper/css";

import { getI18N } from "@/i18n/index";
import { experienceProjects } from "@/lib/experienceProjects";

const { currentLocale } = Astro;
const locale = currentLocale === "en" ? "en" : "es";
const i18n = getI18N({ currentLocale });
const projects = experienceProjects.map((project) => ({
  id: project.id,
  image: project.image,
  href: project.href,
  ...project[locale],
}));
---

<section class="experience-projects font-satoshi" aria-labelledby="experience-projects-title">
  <div class="experience-projects__header inAnimateB">
    <div>
      <h2 id="experience-projects-title" class="text-center">{i18n.ExperienceProjects.title}</h2>
      <p class="text-center">{i18n.ExperienceProjects.description}</p>
    </div>
  </div>
  <p class="experience-projects__eyebrow">{i18n.ExperienceProjects.eyebrow}</p>

  <div class="experience-projects__rail inAnimateB">
    <div class="swiper experience-projects-swiper" aria-label={i18n.ExperienceProjects.slider_label}>
      <div class="swiper-wrapper">
        {
          projects.map((project) => (
            <div class="swiper-slide experience-project-slide">
              <a class="experience-project-card" href={project.href} target="_blank" rel="noopener noreferrer" aria-label={project.title}>
                <span class="experience-project-card__media">
                  <img src={project.image} alt="" loading="lazy" />
                </span>

                <div class="experience-project-card__body">
                  <div>
                    <span class="experience-project-card__index">{project.id}</span>
                    <h3>{project.title}</h3>
                    <p>{project.description}</p>
                  </div>

                  <span class="experience-project-card__link" aria-hidden="true">
                    <span>{project.linkLabel || (locale === "en" ? "View experience" : "Ver experiencia")}</span>
                    <span class="experience-project-card__link-icon">↗</span>
                  </span>
                </div>
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <div class="experience-projects__footer inAnimateB">
    <p>{i18n.ExperienceProjects.drag_hint}</p>
    <div class="experience-projects__controls">
      <button class="experience-projects__nav experience-projects__nav--prev" type="button" aria-label={locale === "en" ? "Previous experience" : "Experiencia anterior"}>
        <span aria-hidden="true">←</span>
      </button>
      <button class="experience-projects__nav experience-projects__nav--next" type="button" aria-label={locale === "en" ? "Next experience" : "Siguiente experiencia"}>
        <span aria-hidden="true">→</span>
      </button>
    </div>
  </div>
</section>

<style>
  .experience-projects {
    width: 100%;
    min-width: 0;
    max-width: 100%;
    display: grid;
    gap: clamp(0.75rem, 2.4vw, 1.45rem);
    overflow: clip;
    contain: inline-size;
  }

  .experience-projects__header {
    display: grid;
    justify-content: center;
    align-items: center;
    gap: clamp(1.25rem, 4vw, 3rem);
  }

  .experience-projects__eyebrow {
    width: fit-content;
    margin: 0;
    border: 1px solid rgba(148, 111, 179, 0.28);
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
    color: rgba(222, 210, 232, 0.76);
    background: rgba(31, 15, 45, 0.26);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .experience-projects h2 {
    margin: 0;
    color: #ffffff;
    font-size: clamp(2.15rem, 4.4vw, 4rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  .experience-projects__header p:last-child {
    max-width: 42rem;
    margin: 0.85rem 0 0;
    color: rgba(255, 255, 255, 0.68);
    line-height: 1.7;
  }

  .experience-projects__rail {
    min-width: 0;
    width: 100%;
    max-width: 100%;
    overflow: clip;
    contain: layout paint inline-size;
    padding-block: 0.5rem 1rem;
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 7%,
      black 93%,
      transparent 100%
    );
  }

  .experience-projects-swiper {
    width: 100%;
    min-width: 0;
    max-width: 100%;
    overflow: hidden;
    contain: layout paint inline-size;
  }

  .experience-projects :global(.swiper-wrapper) {
    max-width: 100%;
  }

  .experience-project-slide {
    height: auto;
    display: flex;
  }

  .experience-project-card {
    width: 100%;
    height: 100%;
    min-height: 20rem;
    display: flex;
    flex-direction: column;
    color: inherit;
    text-decoration: none;
    border: 1px solid rgba(148, 111, 179, 0.26);
    border-radius: 1.15rem;
    background:
      linear-gradient(145deg, rgba(31, 15, 45, 0.72), rgba(15, 17, 21, 0.72)),
      rgba(15, 17, 21, 0.72);
    box-shadow:
      inset 0 1px 0 rgba(222, 210, 232, 0.08),
      0 10px 24px rgba(0, 0, 0, 0.18);
    overflow: hidden;
    transition:
      border-color 0.25s ease,
      transform 0.25s ease,
      box-shadow 0.25s ease;
  }

  .experience-project-card:hover {
    transform: translateY(-4px);
    border-color: rgba(148, 111, 179, 0.52);
    box-shadow:
      inset 0 1px 0 rgba(222, 210, 232, 0.1),
      0 16px 34px rgba(0, 0, 0, 0.24),
      0 0 18px rgba(148, 111, 179, 0.1);
  }

  .experience-project-card__media {
    position: relative;
    display: block;
    aspect-ratio: 16 / 8;
    overflow: hidden;
    background: #0f1115;
  }

  .experience-project-card__media::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(15, 17, 21, 0.04), rgba(15, 17, 21, 0.18)),
      radial-gradient(circle at 80% 20%, rgba(222, 210, 232, 0.18), transparent 34%);
    pointer-events: none;
  }

  .experience-project-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.92) contrast(1.08);
    transition: transform 0.35s ease;
  }

  .experience-project-card:hover .experience-project-card__media img {
    transform: scale(1.045);
  }

  .experience-project-card__body {
    flex: 1;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    padding: clamp(0.9rem, 2vw, 1.12rem);
  }

  .experience-project-card__index {
    display: inline-block;
    margin-bottom: 0.55rem;
    color: rgba(161, 127, 188, 0.8);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .experience-project-card h3 {
    margin: 0;
    color: #ffffff;
    font-size: clamp(1.12rem, 1.8vw, 1.45rem);
    line-height: 1;
    letter-spacing: -0.035em;
  }

  .experience-project-card p {
    margin: 0.58rem 0 0;
    color: rgba(255, 255, 255, 0.66);
    font-size: 0.84rem;
    line-height: 1.52;
  }

  .experience-project-card__link {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: #ded2e8;
    font-size: 0.78rem;
    font-weight: 800;
    white-space: nowrap;
  }

  .experience-project-card__link-icon {
    display: inline-grid;
    width: 2.35rem;
    height: 2.35rem;
    place-items: center;
    border: 1px solid rgba(148, 111, 179, 0.28);
    border-radius: 999px;
    background: rgba(31, 15, 45, 0.28);
    color: #946fb3;
    font-size: 0.95rem;
    transition:
      background 0.25s ease,
      border-color 0.25s ease,
      color 0.25s ease,
      transform 0.25s ease;
  }

  .experience-project-card:hover .experience-project-card__link-icon {
    transform: translate(0.08rem, -0.08rem);
    color: #ffffff;
    border-color: rgba(148, 111, 179, 0.55);
    background: rgba(84, 33, 135, 0.24);
  }

  .experience-projects__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.35rem 0.35rem 0.2rem;
  }

  .experience-projects__footer p {
    margin: 0;
    color: rgba(255, 255, 255, 0.48);
    font-size: 0.82rem;
  }

  .experience-projects__controls {
    display: flex;
    gap: 0.6rem;
  }

  .experience-projects__nav {
    display: inline-grid;
    width: 2.65rem;
    height: 2.65rem;
    place-items: center;
    border: 1px solid rgba(148, 111, 179, 0.3);
    border-radius: 999px;
    background: rgba(31, 15, 45, 0.32);
    color: #ded2e8;
    cursor: pointer;
    transition:
      background 0.25s ease,
      border-color 0.25s ease,
      color 0.25s ease,
      transform 0.25s ease,
      opacity 0.25s ease;
  }

  .experience-projects__nav:hover {
    transform: translateY(-2px);
    color: #ffffff;
    border-color: rgba(148, 111, 179, 0.56);
    background: rgba(84, 33, 135, 0.24);
  }

  .experience-projects__nav.swiper-button-disabled {
    opacity: 0.38;
    cursor: not-allowed;
    transform: none;
  }

  @media (max-width: 800px) {
    .experience-projects__rail {
      mask-image: none;
      padding-block: 0.25rem 0.75rem;
      overflow: clip;
    }

    .experience-projects-swiper {
      overflow: clip;
    }

    .experience-projects :global(.swiper-wrapper) {
      width: 100% !important;
      transform: none !important;
    }

    .experience-project-slide {
      width: 100% !important;
      margin-right: 0 !important;
      position: absolute;
      inset: 0;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
    }

    .experience-project-slide.swiper-slide-active {
      position: relative;
      display: flex;
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }

    .experience-projects__header {
      grid-template-columns: 1fr;
      text-align: center;
      justify-items: center;
    }

    .experience-project-card {
      width: min(82vw, 21rem);
      min-height: 19.5rem;
      margin-inline: auto;
    }

    .experience-project-card__body {
      align-items: flex-start;
      flex-direction: column;
    }

    .experience-project-card__link {
      width: 100%;
      justify-content: space-between;
    }

    .experience-projects__footer {
      justify-content: center;
      flex-direction: column;
      text-align: center;
    }

    .experience-projects__controls {
      display: flex;
    }
  }
</style>

<script>
  import Swiper from "swiper";
  import { Keyboard, Navigation } from "swiper/modules";

  new Swiper(".experience-projects-swiper", {
    modules: [Keyboard, Navigation],
    slidesPerView: 1,
    spaceBetween: 18,
    centeredSlides: false,
    grabCursor: true,
    keyboard: {
      enabled: true,
    },
    navigation: {
      prevEl: ".experience-projects__nav--prev",
      nextEl: ".experience-projects__nav--next",
    },
    breakpoints: {
      720: {
        slidesPerView: 2.45,
        spaceBetween: 22,
        centeredSlides: false,
      },
      1100: {
        slidesPerView: 3.2,
        spaceBetween: 24,
        centeredSlides: false,
      },
      1536: {
        slidesPerView: 3.8,
        spaceBetween: 26,
        centeredSlides: false,
      },
    },
  });
</script>
