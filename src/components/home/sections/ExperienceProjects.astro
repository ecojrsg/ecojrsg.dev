---
import "swiper/css";

import BlogLinkButton from "@/components/BlogLinkButton.astro";
import { getI18N } from "@/i18n/index";
import { experienceProjects } from "@/lib/experienceProjects";

const { currentLocale } = Astro;
const locale = currentLocale === "en" ? "en" : "es";
const i18n = getI18N({ currentLocale });
const projects = experienceProjects.map((project) => ({
  id: project.id,
  image: project.image,
  href: project.href,
  ...project[locale],
}));
---

<section class="experience-projects font-satoshi" aria-labelledby="experience-projects-title">
  <div class="experience-projects__header inAnimateB">
    <div>
      <h2 id="experience-projects-title" class="text-center">{i18n.ExperienceProjects.title}</h2>
      <p class="text-center">{i18n.ExperienceProjects.description}</p>
    </div>
  </div>
  <p class="experience-projects__eyebrow">{i18n.ExperienceProjects.eyebrow}</p>

  <div class="experience-projects__rail inAnimateB">
    <div class="swiper experience-projects-swiper" aria-label={i18n.ExperienceProjects.slider_label}>
      <div class="swiper-wrapper">
        {
          projects.map((project) => (
            <article class="swiper-slide experience-project-card">
              <a class="experience-project-card__media" href={project.href} target="_blank" rel="noopener noreferrer" aria-label={project.title}>
                <img src={project.image} alt="" loading="lazy" />
              </a>

              <div class="experience-project-card__body">
                <div>
                  <span class="experience-project-card__index">{project.id}</span>
                  <h3>{project.title}</h3>
                  <p>{project.description}</p>
                </div>

                <BlogLinkButton
                  href={project.href}
                  labelEs={project.linkLabel || "Ver experiencia"}
                  labelEn={project.linkLabel || "View experience"}
                  blank
                  class="experience-project-card__link"
                />
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>

  <div class="experience-projects__footer inAnimateB">
    <p>{i18n.ExperienceProjects.drag_hint}</p>
    <div class="experience-projects__controls" aria-hidden="true">
      <span></span>
      <span></span>
    </div>
  </div>
</section>

<style>
  .experience-projects {
    width: 100%;
    min-width: 0;
    display: grid;
    gap: clamp(0.8rem, 3vw, 1.8rem);
    overflow: hidden;
  }

  .experience-projects__header {
    display: grid;
    justify-content: center;
    align-items: center;
    gap: clamp(1.25rem, 4vw, 3rem);
  }

  .experience-projects__eyebrow {
    width: fit-content;
    margin: 0;
    border: 1px solid rgba(148, 111, 179, 0.28);
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
    color: rgba(222, 210, 232, 0.76);
    background: rgba(31, 15, 45, 0.26);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .experience-projects h2 {
    margin: 0;
    color: #ffffff;
    font-size: clamp(2.15rem, 4.4vw, 4rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  .experience-projects__header p:last-child {
    max-width: 42rem;
    margin: 0.85rem 0 0;
    color: rgba(255, 255, 255, 0.68);
    line-height: 1.7;
  }

  .experience-projects__rail {
    min-width: 0;
    width: 100%;
    overflow: hidden;
    padding-block: 0.9rem 1.9rem;
    margin-block: -0.9rem -1.9rem;
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 7%,
      black 93%,
      transparent 100%
    );
  }

  .experience-projects-swiper {
    width: 100%;
    min-width: 0;
    overflow: visible;
  }

  .experience-project-card {
    height: auto;
    min-height: 25rem;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(148, 111, 179, 0.26);
    border-radius: 1.35rem;
    background:
      linear-gradient(145deg, rgba(31, 15, 45, 0.72), rgba(15, 17, 21, 0.72)),
      rgba(15, 17, 21, 0.72);
    box-shadow:
      inset 0 1px 0 rgba(222, 210, 232, 0.08),
      0 20px 54px rgba(0, 0, 0, 0.34),
      0 0 34px rgba(148, 111, 179, 0.08);
    overflow: hidden;
    transition:
      border-color 0.25s ease,
      transform 0.25s ease,
      box-shadow 0.25s ease;
  }

  .experience-project-card:hover {
    transform: translateY(-4px);
    border-color: rgba(148, 111, 179, 0.52);
    box-shadow:
      inset 0 1px 0 rgba(222, 210, 232, 0.1),
      0 26px 70px rgba(0, 0, 0, 0.36),
      0 0 24px rgba(148, 111, 179, 0.12);
  }

  .experience-project-card__media {
    position: relative;
    display: block;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #0f1115;
  }

  .experience-project-card__media::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, transparent 42%, rgba(15, 17, 21, 0.84)),
      radial-gradient(circle at 80% 20%, rgba(222, 210, 232, 0.18), transparent 34%);
    pointer-events: none;
  }

  .experience-project-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.92) contrast(1.08);
    transition: transform 0.35s ease;
  }

  .experience-project-card:hover .experience-project-card__media img {
    transform: scale(1.045);
  }

  .experience-project-card__body {
    flex: 1;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.35rem;
    padding: clamp(1.05rem, 2.6vw, 1.45rem);
  }

  .experience-project-card__index {
    display: inline-block;
    margin-bottom: 0.72rem;
    color: rgba(161, 127, 188, 0.8);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .experience-project-card h3 {
    margin: 0;
    color: #ffffff;
    font-size: clamp(1.35rem, 2.4vw, 1.75rem);
    line-height: 1;
    letter-spacing: -0.035em;
  }

  .experience-project-card p {
    margin: 0.75rem 0 0;
    color: rgba(255, 255, 255, 0.66);
    font-size: 0.92rem;
    line-height: 1.62;
  }

  .experience-project-card__link {
    flex: 0 0 auto;
  }

  .experience-projects__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1rem 0.35rem 0.2rem;
  }

  .experience-projects__footer p {
    margin: 0;
    color: rgba(255, 255, 255, 0.48);
    font-size: 0.82rem;
  }

  .experience-projects__controls {
    display: flex;
    gap: 0.45rem;
  }

  .experience-projects__controls span {
    width: 2rem;
    height: 0.18rem;
    border-radius: 999px;
    background: rgba(148, 111, 179, 0.42);
  }

  @media (max-width: 800px) {
    .experience-projects__header {
      grid-template-columns: 1fr;
      text-align: center;
      justify-items: center;
    }

    .experience-project-card__body {
      align-items: flex-start;
      flex-direction: column;
    }

    .experience-projects__footer {
      justify-content: center;
      text-align: center;
    }

    .experience-projects__controls {
      display: none;
    }
  }
</style>

<script>
  import Swiper from "swiper";
  import { Keyboard } from "swiper/modules";

  new Swiper(".experience-projects-swiper", {
    modules: [Keyboard],
    slidesPerView: 1.12,
    spaceBetween: 18,
    grabCursor: true,
    keyboard: {
      enabled: true,
    },
    breakpoints: {
      720: {
        slidesPerView: 2.15,
        spaceBetween: 22,
      },
      1100: {
        slidesPerView: 3.18,
        spaceBetween: 24,
      },
    },
  });
</script>
