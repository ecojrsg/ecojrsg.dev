---
import "swiper/css";
import "swiper/css/effect-cards";

import Logo from "@/components/Logo.astro";
import Emilio from "@/components/icons/Emilio.astro";
import Yari from "@/components/icons/Yari.astro";
import Sebas from "@/components/icons/Sebas.astro";
import { getI18N } from "@/i18n/index";
import { teamMembers, type TeamMemberIcon } from "@/lib/team";

const { currentLocale } = Astro;
const locale = currentLocale === "en" ? "en" : "es";
const i18n = getI18N({ currentLocale });

const memberIcons: Record<TeamMemberIcon, typeof Logo> = {
  eco: Logo,
  yari: Yari,
  emilio: Emilio,
  sebas: Sebas,
};

const teamPayload = teamMembers.map((member) => ({
  id: member.id,
  ...member[locale],
}));

const firstMember = teamPayload[0];
---

<section class="team-section font-satoshi" aria-labelledby="team-title">
  <div class="team-section__header inAnimateB">
    <p class="team-section__eyebrow">{i18n.Team.eyebrow}</p>
    <h1 id="team-title">{i18n.Team.title}</h1>
    <p>{i18n.Team.description}</p>
  </div>

  <div class="team-section__content">
    <div class="team-section__slider inAnimateL" aria-label={i18n.Team.slider_label}>
      <div class="swiper team-cards-swiper">
        <div class="swiper-wrapper">
          {
            teamMembers.map((member) => {
              const Icon = memberIcons[member.icon];
              const name = member[locale].name;

              return (
                <div class="swiper-slide team-card-slide" data-member-id={member.id}>
                  <div class="team-card">
                    <Icon class="team-card__icon" aria-hidden="true" />
                    <span class="sr-only">{name}</span>
                  </div>
                </div>
              );
            })
          }
        </div>
      </div>
      <p class="team-section__drag-hint">{i18n.Team.drag_hint}</p>
    </div>

    <div class="team-info inAnimateR">
      <div class="team-info__meta">
        <span class="team-info__status">{i18n.Team.active_label}</span>
        <span id="team-count">01 / {String(teamPayload.length).padStart(2, "0")}</span>
      </div>

      <div class="team-info__identity">
        <h2 id="team-member-name" data-team-name>{firstMember.name}</h2>
        <p id="team-member-role" class="team-info__role">{firstMember.role}</p>
      </div>

      <div class="team-info__description-card">
        <p id="team-member-description" class="team-info__description">
          {firstMember.description}
        </p>
      </div>

      <ul id="team-member-highlights" class="team-info__highlights">
        {firstMember.highlights.map((highlight) => <li>{highlight}</li>)}
      </ul>
    </div>
  </div>

  <script is:inline type="application/json" id="team-members-data" set:html={JSON.stringify(teamPayload)} />
</section>

<style>
  .team-section {
    width: 100%;
    display: grid;
    gap: clamp(3rem, 7vw, 5.5rem);
    padding-block: clamp(1rem, 3vw, 2rem);
  }

  .team-section__header {
    max-width: 48rem;
    display: grid;
    gap: 0.75rem;
  }

  .team-section__eyebrow {
    width: fit-content;
    border: 1px solid rgba(148, 111, 179, 0.28);
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
    color: rgba(222, 210, 232, 0.76);
    background: rgba(31, 15, 45, 0.26);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .team-section__header h1 {
    margin: 0;
    color: white;
    font-size: clamp(2.6rem, 5vw, 4.75rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
  }

  .team-section__header p:last-child {
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.7;
  }

  .team-section__content {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(19rem, 24rem);
    align-items: center;
    gap: clamp(4rem, 9vw, 8rem);
  }

  .team-section__slider {
    order: 2;
    display: grid;
    justify-items: center;
    gap: 1.15rem;
    min-width: 0;
  }

  .team-cards-swiper {
    width: min(72vw, 20rem);
    height: min(78vw, 25rem);
    overflow: visible;
  }

  .team-card-slide {
    display: grid;
    place-items: center;
    cursor: grab;
    opacity: 0.72;
    transition: opacity 0.25s ease;
  }

  .team-card-slide.swiper-slide-active {
    opacity: 1;
  }

  .team-card-slide:active {
    cursor: grabbing;
  }

  .team-card {
    width: 100%;
    height: 100%;
    position: relative;
    display: grid;
    place-items: center;
    align-content: center;
    padding: clamp(1.75rem, 4vw, 2.5rem);
    background:
      radial-gradient(circle at 50% 16%, rgba(148, 111, 179, 0.25), transparent 40%),
      linear-gradient(145deg, #241234 0%, #17121d 52%, #0d0f13 100%);
    border: 1px solid rgba(148, 111, 179, 0.42);
    border-radius: 1.65rem;
    box-shadow:
      0 30px 80px rgba(0, 0, 0, 0.42),
      inset 0 1px 0 rgba(222, 210, 232, 0.08),
      inset 0 -28px 70px rgba(0, 0, 0, 0.18);
    overflow: hidden;
  }

  .team-card::after {
    content: "";
    position: absolute;
    inset: 0.65rem;
    border: 1px solid rgba(222, 210, 232, 0.08);
    border-radius: 1.25rem;
    pointer-events: none;
  }

  .team-card__icon {
    position: relative;
    z-index: 1;
    width: min(78%, 13.5rem);
    height: auto;
    max-height: 16.5rem;
    filter: drop-shadow(0 26px 42px rgba(0, 0, 0, 0.38));
    transition:
      opacity 0.25s ease,
      transform 0.25s ease;
  }

  .team-card-slide:not(.swiper-slide-active) .team-card {
    background:
      radial-gradient(circle at 50% 16%, rgba(148, 111, 179, 0.14), transparent 40%),
      linear-gradient(145deg, #1b1027 0%, #111016 56%, #090b0e 100%);
    border-color: rgba(148, 111, 179, 0.28);
  }

  .team-card-slide:not(.swiper-slide-active) .team-card__icon {
    opacity: 0;
    transform: scale(0.9);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .team-section__drag-hint {
    color: rgba(255, 255, 255, 0.52);
    font-size: 0.82rem;
  }

  .team-info {
    position: relative;
    box-sizing: border-box;
    min-height: 29rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: clamp(1.1rem, 2.4vw, 1.55rem);
    padding: clamp(1.5rem, 4vw, 3rem);
    overflow: hidden;
    border: 1px solid rgba(148, 111, 179, 0.28);
    border-radius: 1.75rem;
    background:
      radial-gradient(circle at 94% 10%, rgba(148, 111, 179, 0.18), transparent 36%),
      linear-gradient(145deg, rgba(31, 15, 45, 0.78), rgba(15, 17, 21, 0.52));
    box-shadow:
      0 24px 80px rgba(0, 0, 0, 0.28),
      inset 0 1px 0 rgba(222, 210, 232, 0.08);
  }

  .team-info::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(135deg, rgba(222, 210, 232, 0.18), transparent 38%, rgba(148, 111, 179, 0.16));
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    mask-composite: exclude;
    -webkit-mask-composite: xor;
    pointer-events: none;
  }

  .team-info__meta {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    color: rgba(161, 127, 188, 0.72);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.78rem;
  }

  .team-info__status {
    width: fit-content;
    border: 1px solid rgba(148, 111, 179, 0.24);
    border-radius: 999px;
    padding: 0.38rem 0.7rem;
    background: rgba(31, 15, 45, 0.34);
    color: rgba(222, 210, 232, 0.72);
  }

  .team-info__identity {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 0.85rem;
    padding-block: 0.45rem 0.2rem;
  }

  .team-info h2 {
    min-height: 1.12em;
    margin: 0;
    color: #ffffff;
    font-size: clamp(2.15rem, 4.4vw, 3.9rem);
    line-height: 1;
    letter-spacing: -0.055em;
    text-wrap: balance;
  }

  .team-info__role {
    width: fit-content;
    margin: 0;
    border: 1px solid rgba(148, 111, 179, 0.3);
    padding: 0.55rem 0.85rem;
    border-radius: 999px;
    color: #ded2e8;
    background: rgba(148, 111, 179, 0.14);
    font-size: 0.95rem;
    font-weight: 800;
    letter-spacing: 0.02em;
  }

  .team-info__description-card {
    position: relative;
    z-index: 1;
    box-sizing: border-box;
    border: 1px solid rgba(148, 111, 179, 0.18);
    border-radius: 1.2rem;
    padding: clamp(1rem, 2.5vw, 1.35rem);
    background:
      radial-gradient(circle at 8% 0%, rgba(148, 111, 179, 0.16), transparent 42%),
      rgba(15, 17, 21, 0.24);
    box-shadow: inset 0 1px 0 rgba(222, 210, 232, 0.05);
  }

  .team-info__description-card::before {
    content: none;
  }

  .team-info__description {
    max-width: 42rem;
    margin: 0;
    padding: 0;
    color: rgba(255, 255, 255, 0.76);
    line-height: 1.78;
    font-size: 0.98rem;
  }

  .team-info__highlights {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .team-info__highlights li {
    border: 1px solid rgba(148, 111, 179, 0.34);
    border-radius: 999px;
    padding: 0.48rem 0.78rem;
    color: rgba(222, 210, 232, 0.82);
    background: rgba(31, 15, 45, 0.36);
    font-size: 0.78rem;
    font-weight: 700;
    box-shadow: inset 0 1px 0 rgba(222, 210, 232, 0.05);
  }

  @media (max-width: 900px) {
    .team-section__content {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .team-section__slider {
      order: 1;
    }

    .team-info {
      order: 2;
    }

    .team-section__header {
      text-align: center;
      justify-items: center;
      margin-inline: auto;
    }

    .team-info {
      min-height: 23rem;
    }
  }

  @media (max-width: 640px) {
    .team-cards-swiper {
      width: min(74vw, 17rem);
      height: min(84vw, 21.5rem);
    }

    .team-card {
      padding: 1.5rem;
    }

    .team-info__meta {
      font-size: 0.7rem;
    }

    .team-info {
      padding: 1.25rem;
      border-radius: 1.35rem;
    }

    .team-info__meta {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.65rem;
    }

    .team-info__description-card {
      border-radius: 1rem;
    }
  }
</style>

<script>
  import Swiper from "swiper";
  import { EffectCards, Keyboard } from "swiper/modules";

  const dataElement = document.getElementById("team-members-data");
  const teamMembers = dataElement?.textContent ? JSON.parse(dataElement.textContent) : [];

  const nameElement = document.getElementById("team-member-name");
  const roleElement = document.getElementById("team-member-role");
  const descriptionElement = document.getElementById("team-member-description");
  const highlightsElement = document.getElementById("team-member-highlights");
  const countElement = document.getElementById("team-count");

  type TeamViewModel = {
    id: string;
    name: string;
    role: string;
    description: string;
    highlights: string[];
  };

  let typewriterTimeout: number | undefined;
  let typewriterRun = 0;

  const writeName = (name: string) => {
    if (!nameElement) return;

    if (typewriterTimeout) window.clearTimeout(typewriterTimeout);

    typewriterRun += 1;
    const currentRun = typewriterRun;
    nameElement.textContent = "";

    const typeNextCharacter = (index: number) => {
      if (currentRun !== typewriterRun || !nameElement) return;

      nameElement.textContent = `${name.slice(0, index)}${index < name.length ? "|" : ""}`;

      if (index <= name.length) {
        typewriterTimeout = window.setTimeout(() => typeNextCharacter(index + 1), 42);
      }
    };

    typeNextCharacter(1);
  };

  const updateMemberInfo = (index: number) => {
    const member = (teamMembers as TeamViewModel[])[index];
    if (!member) return;

    writeName(member.name);

    if (roleElement) roleElement.textContent = member.role;
    if (descriptionElement) descriptionElement.textContent = member.description;
    if (countElement) {
      countElement.textContent = `${String(index + 1).padStart(2, "0")} / ${String(teamMembers.length).padStart(2, "0")}`;
    }

    if (highlightsElement) {
      highlightsElement.replaceChildren(
        ...member.highlights.map((highlight: string) => {
          const item = document.createElement("li");
          item.textContent = highlight;
          return item;
        }),
      );
    }
  };

  const swiper = new Swiper(".team-cards-swiper", {
    modules: [EffectCards, Keyboard],
    init: false,
    effect: "cards",
    grabCursor: true,
    loop: true,
    keyboard: {
      enabled: true,
    },
    cardsEffect: {
      perSlideOffset: 18,
      perSlideRotate: 1.5,
      rotate: true,
      slideShadows: false,
    },
    on: {
      init(instance) {
        updateMemberInfo(instance.realIndex);
      },
      slideChange(instance) {
        updateMemberInfo(instance.realIndex);
      },
    },
  });

  swiper.init();
</script>
