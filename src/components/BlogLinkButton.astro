---
interface Props {
  href?: string;
  label?: string;
  labelEs?: string;
  labelEn?: string;
  blank?: boolean;
  class?: string;
}

const {
  href = "",
  label,
  labelEs,
  labelEn,
  blank = false,
  class: className = "",
} = Astro.props;

const defaultLabel = Astro.currentLocale === "en" ? "Read more on my blog" : "Leer mas en mi blog";
const localizedLabel = Astro.currentLocale === "en" ? labelEn : labelEs;
const buttonLabel = label?.trim() || localizedLabel?.trim() || defaultLabel;

const target = blank ? "_blank" : undefined;
const rel = blank ? "noopener noreferrer" : undefined;
---

<a
  href={href}
  target={target}
  rel={rel}
  aria-label={buttonLabel}
  class:list={["blog-link-button", className]}
>
  <span class="blog-link-button__tooltip" aria-hidden="true">{buttonLabel}</span>
  <span class="blog-link-button__icon" aria-hidden="true">↗</span>
</a>

<style>
  .blog-link-button {
    position: relative;
    display: inline-grid;
    width: 2.75rem;
    height: 2.75rem;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(148, 111, 179, 0.28);
    border-radius: 999px;
    background: rgba(31, 15, 45, 0.28);
    color: #ded2e8;
    text-decoration: none;
    box-shadow: 0 8px 24px rgba(15, 17, 21, 0.22);
    transition:
      background 0.25s ease,
      border-color 0.25s ease,
      color 0.25s ease,
      box-shadow 0.25s ease,
      transform 0.25s ease;
  }

  .blog-link-button:hover {
    transform: translateY(-2px) scale(1.02);
    color: #ffffff;
    border-color: rgba(148, 111, 179, 0.55);
    background: rgba(84, 33, 135, 0.24);
    box-shadow:
      0 0 18px rgba(148, 111, 179, 0.18),
      inset 0 1px 0 rgba(222, 210, 232, 0.08);
  }

  .blog-link-button__icon {
    font-size: 1.05rem;
    color: #946fb3;
    transition: transform 0.25s ease;
  }

  .blog-link-button:hover .blog-link-button__icon {
    transform: translate(0.08rem, -0.08rem);
  }

  .blog-link-button__tooltip {
    position: absolute;
    top: 50%;
    right: calc(100% + 0.7rem);
    transform: translate(0.35rem, -50%) scale(0.96);
    width: max-content;
    max-width: 12rem;
    padding: 0.55rem 0.75rem;
    border: 1px solid rgba(148, 111, 179, 0.34);
    border-radius: 0.75rem;
    background: rgba(31, 15, 45, 0.96);
    color: #ded2e8;
    font-family: "Satoshi", sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    line-height: 1.2;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    box-shadow: 0 10px 28px rgba(15, 17, 21, 0.32);
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  .blog-link-button__tooltip::after {
    content: "";
    position: absolute;
    top: 50%;
    right: -5px;
    width: 9px;
    height: 9px;
    border-top: 1px solid rgba(148, 111, 179, 0.34);
    border-right: 1px solid rgba(148, 111, 179, 0.34);
    background: rgba(31, 15, 45, 0.96);
    transform: translateY(-50%) rotate(45deg);
  }

  .blog-link-button:hover .blog-link-button__tooltip,
  .blog-link-button:focus-visible .blog-link-button__tooltip {
    opacity: 1;
    transform: translate(0, -50%) scale(1);
  }

  @media (max-width: 639px) {
    .blog-link-button {
      width: 2.75rem;
    }
  }
</style>
